
<!DOCTYPE html>
<html>
<head>
    
    <title>Controllo Patente</title>
  
       
        
 <input>
 <body>
    <h1>Verifica Patente</h1>

    <input type="text" id="nome" placeholder="Nome"><br>
    <input type="text" id="cognome" placeholder="Cognome"><br>
    <input type="number" id="eta" placeholder="Età"><br>

    <button onclick="verifica()">Verifica</button>

    <div id="risultato"></div>

    <script>
        function verifica() {
            let nome = document.getElementById("nome").value;
            let cognome = document.getElementById("cognome").value;
            let eta = parseInt(document.getElementById("eta").value);
            let risultato = document.getElementById("risultato");

            risultato.innerHTML = "";

            if (isNaN(eta)) {
                risultato.innerHTML = "<p>Inserisci un'età valida</p>";
                return;
            }

            if (eta >= 18) {
                risultato.innerHTML = `
                    <p>${nome} ${cognome}, puoi avere la patente B (auto)</p>
                    <img src="https://via.placeholder.com/300x180?text=Patente+B" alt="Patente B">
                `;
            } else if (eta >= 16) {
                risultato.innerHTML = `
                    <p>${nome} ${cognome}, puoi avere la patente A (moto)</p>
                    <img src="https://via.placeholder.com/300x180?text=Patente+A" alt="Patente A">
                `;
            } else {
                risultato.innerHTML = `
                    <p>${nome} ${cognome}, riprova quando sarai più grande</p>
                `;
            }
        }
    </script>

</body>
</html>
