
<!DOCTYPE html>
<html>
<head>
    <title>Controllo Patente</title>
</head>
<body>

<h1>Verifica Patente</h1>

<p id="demo"></p>

<img id="myimage" src="https://upload.wikimedia.org/wikipedia/commons/8/89/Portrait_Placeholder.png">

<br><br>

<button onclick="verifica()">Verifica</button>

<script>

let text = "Non sei idoneo, riprova quando sarai più grande!";

let nome = prompt("Inserisci nome");
let cognome = prompt("Inserisci cognome");
let eta = Number(prompt("Inserisci età"));

function verifica() {

    if (eta >= 18) {
        document.getElementById("myimage").src = "https://upload.wikimedia.org/wikipedia/commons/c/c1/IT_licence_%28front%29.jpg";
    } 
    else if (eta >= 16) {
        document.getElementById("myimage").src = "https://www.chiarezza.it/wp-content/uploads/2013/07/patente.jpg";
    } 
    else {
        document.getElementById("demo").innerHTML = text;
    }

}

</script>

</body>
</html>
